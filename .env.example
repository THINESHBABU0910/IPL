PORT=3000

# Optional — unlock thousands of searchable GIFs in chat (local catalog works without these)
# Both keys are used in round-robin (100 requests/hour each on free tier).
GIPHY_API_KEY_A=your_giphy_key_a
GIPHY_API_KEY_B=your_giphy_key_b
# Legacy single-key fallback (optional)
# GIPHY_API_KEY=

# LLM is tried first; local simulation is the fallback on timeout/504/errors.
# Set AI_SIM_USE_LLM=false to skip LLM and use local sim only.
# AI_SIM_USE_LLM=true

# AI Gateway (OpenAI-compatible chat completions)
AI_GATEWAY_BASE_URL=https://aigateway-uat.sifymdp.digital/api/v1
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=meta-llama/Llama-3.1-8B-Instruct
